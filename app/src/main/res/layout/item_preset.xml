<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/input_background"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <!-- Preset info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tvPresetName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preset name"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvPresetDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192.168.0.1:9021 • payload.bin"
            android:textSize="12sp"
            android:textColor="@color/textSecondary"/>
    </LinearLayout>

    <!-- Load button -->
    <Button
        android:id="@+id/btnLoadPreset"
        android:layout_width="60dp"
        android:layout_height="36dp"
        android:text="Load"
        android:textSize="11sp"
        android:textColor="@color/white"
        android:background="@drawable/button_primary_background"
        android:layout_marginEnd="6dp"/>

    <!-- Delete button -->
    <Button
        android:id="@+id/btnDeletePreset"
        android:layout_width="60dp"
        android:layout_height="36dp"
        android:text="✕"
        android:textSize="14sp"
        android:textColor="@color/statusError"
        android:background="@drawable/button_secondary_background"/>
</LinearLayout>
